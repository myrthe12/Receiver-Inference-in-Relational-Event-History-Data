# --- 6. Helper function to build traces ---
def build_traces(G_sub, show_colorbar=False):
    edge_traces = []
    max_weight = max([d['weight'] for _, _, d in G_sub.edges(data=True)]) if G_sub.number_of_edges() > 0 else 1

    for u,v,data in G_sub.edges(data=True):
        x0,y0 = G_sub.nodes[u]['pos']
        x1,y1 = G_sub.nodes[v]['pos']
        weight = data['weight']
        width = 0.5 + (weight / max_weight) * 5
        edge_traces.append(go.Scatter(
            x=[x0,x1,None],
            y=[y0,y1,None],
            line=dict(width=width,color='#888'),
            mode='lines',
            hoverinfo='text',
            text=f'{u} → {v}<br>Weight: {weight}'
        ))

    node_x, node_y, node_color, node_text = [], [], [], []
    for node in G_sub.nodes():
        x,y = G_sub.nodes[node]['pos']
        node_x.append(x)
        node_y.append(y)
        in_deg = G_sub.in_degree(node)
        out_deg = G_sub.out_degree(node)
        node_color.append(in_deg + out_deg)
        node_text.append(f"ID {node}<br>In:{in_deg} Out:{out_deg}")

    node_trace = go.Scatter(
        x=node_x, y=node_y,
        mode='markers',
        text=[str(node) for node in G_sub.nodes()],
        textposition='top center',
        hoverinfo='text',
        marker=dict(
            showscale=show_colorbar,
            colorscale='YlGnBu',
            reversescale=True,
            color=node_color,
            size=12,
            line_width=2,
            colorbar=dict(
                thickness=15,
                title=dict(text='Node Connections')
            ) if show_colorbar else None
        )
    )
    #node_trace.text = node_text
    return edge_traces + [node_trace]

