        counts_correct = np.zeros(n_bins)
        counts_wrong = np.zeros(n_bins)
        counts_total = np.zeros(n_bins)
        accuracy_per_bin = np.zeros(n_bins)

        for i in range(n_bins):
            mask = bin_indices == i
            counts_total[i] = mask.sum()
            counts_correct[i] = debug_df.loc[mask, 'correct'].sum()
            counts_wrong[i] = counts_total[i] - counts_correct[i]
            accuracy_per_bin[i] = counts_correct[i] / max(counts_total[i], 1)

        # --- Top row: counts ---
