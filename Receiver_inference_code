# Compute Expected Calibration Error (ECE), lower indicates better calibaration
def compute_ece(y_true, y_prob, n_bins=10):
    bins = np.linspace(0.0, 1.0, n_bins + 1)
    bin_indices = np.digitize(y_prob, bins) - 1  # Bin assignment for each sample

    ece = 0.0
    total_samples = len(y_prob)

    for i in range(n_bins):
        bin_mask = bin_indices == i
        bin_size = np.sum(bin_mask)

        if bin_size > 0:
            bin_confidence = np.mean(y_prob[bin_mask])
            bin_accuracy = np.mean(y_true[bin_mask])
            ece += (bin_size / total_samples) * np.abs(bin_accuracy - bin_confidence)

    return ece

