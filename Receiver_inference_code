def plot_calibration_2x2(debug_df, n_bins=10, x_label_dict=None):
    """
    Plots 4 calibration plots in a 2x2 grid:
    Top: counts (left: avg_prob, right: confidence_score)
    Bottom: accuracy (left: avg_prob, right: confidence_score)
    """
    prob_cols = ['avg_prob', 'confidence_score']
    bin_edges = np.linspace(0, 1, n_bins + 1)
    bin_centers = (bin_edges[:-1] + bin_edges[1:]) / 2

    # Colors
    color_correct = 'tab:blue'
    color_wrong = 'tab:red'
    color_acc = 'tab:blue'

    # Default x-axis labels
    if x_label_dict is None:
        x_label_dict = {'avg_prob': 'Mean per-token probability', 'confidence_score': 'Model confidence'}

    fig, axes = plt.subplots(2, 2, figsize=(14, 10))
    axes = axes.flatten()  # easier indexing

    for i, prob_col in enumerate(prob_cols):
        # Assign bins
        bin_indices = np.digitize(debug_df[prob_col], bin_edges) - 1
        bin_indices = np.clip(bin_indices, 0, n_bins - 1)

        counts_correct = np.zeros(n_bins)
        counts_wrong = np.zeros(n_bins)
        counts_total = np.zeros(n_bins)
        accuracy_per_bin = np.zeros(n_bins)

        for j in range(n_bins):
            mask = bin_indices == j
            counts_total[j] = mask.sum()
            counts_correct[j] = debug_df.loc[mask, 'correct'].sum()
            counts_wrong[j] = counts_total[j] - counts_correct[j]
            accuracy_per_bin[j] = counts_correct[j] / max(counts_total[j], 1)

        # --- Counts plot ---
        axes[i].bar(bin_centers, counts_correct, width=0.08, alpha=0.9, color=color_correct, label='Correct')
        axes[i].bar(bin_centers, counts_wrong, width=0.08, bottom=counts_correct, alpha=0.9, color=color_wrong, label='Wrong')
        axes[i].set_xlabel(x_label_dict.get(prob_col, prob_col))
        axes[i].set_ylabel('Count')
        axes[i].set_title(f'Prediction counts ({prob_col})')
        axes[i].legend()
        axes[i].grid(True, axis='y')

        # --- Accuracy plot ---
        axes[i+2].bar(bin_centers, accuracy_per_bin, width=0.08, alpha=0.9, color=color_acc, label='Accuracy')
        axes[i+2].plot([0, 1], [0, 1], 'k--', label='Perfect calibration')
        axes[i+2].set_xlabel(x_label_dict.get(prob_col, prob_col))
        axes[i+2].set_ylabel('Accuracy within bin')
        axes[i+2].set_title(f'Calibration: Accuracy ({prob_col})')
        axes[i+2].legend()
        axes[i+2].grid(True)

    plt.tight_layout()
    plt.show()


