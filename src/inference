results = []

# --- Process data ---
for i, item in enumerate(conversation_data):
    try:
        # --- Step 1a: Get raw response with logprobs ---
        messages = [
            SystemMessage(content=prompt_1),
            HumanMessage(content=f"""<sender>{item.get('sender', '')}</sender>
                                      <message>{item.get('message', '')}</message>
                                      <history>{item.get('conversation_history', '')}</history>""")
        ]
        raw_msg = llm_receiver.invoke(messages)
        raw_text = raw_msg.content.strip()  # predicted receiver
        logprobs_content = raw_msg.response_metadata.get("logprobs", {}).get("content")
        avg_logprob = (sum(token['logprob'] for token in logprobs_content) / len(logprobs_content)) if logprobs_content else None
        avg_prob_percent = math.exp(avg_logprob)*100 if avg_logprob is not None else None

        predicted_receiver = raw_text

        # --- Step 2: Confidence scoring ---
        messages_conf = [
            SystemMessage(content=prompt_2),
            HumanMessage(content=f"Sender: {item.get('sender', '')}\n"
                                 f"Message: {item.get('message', '')}\n"
                                 f"History: {item.get('conversation_history', '')}\n"
                                 f"Predicted Receiver: {predicted_receiver}")
        ]
        msg_conf = llm_confidence.invoke(messages_conf)
        try:
            confidence_score = float(msg_conf.content.strip())
        except ValueError:
            confidence_score = None

        # --- Store results ---
        results.append({
            "sender": item.get("sender", ""),
            "message": item.get("message", ""),
            "conversation_history": item.get("conversation_history", ""),
            "actual_receiver": item.get("receiver", ""),
            "predicted_receiver": predicted_receiver,
            "confidence_score": confidence_score,
            "logprobs_content": logprobs_content,
            "avg_logprob": avg_logprob,
            "avg_prob_percent": avg_prob_percent
        })

    except Exception as e:
        print(f"Error processing item {i}: {e}")
        results.append({
            "sender": item.get("sender", ""),
            "message": item.get("message", ""),
            "conversation_history": item.get("conversation_history", ""),
            "actual_receiver": item.get("receiver", ""),
            "predicted_receiver": None,
            "confidence_score": None,
            "logprobs_content": None,
            "avg_logprob": None,
            "avg_prob_percent": None,
            "error": str(e)
        })
        continue

